{% extends 'layout/master.njk' %}

{% block content %}
<style>
.location-cell{position:relative;display:inline-flex;align-items:center;cursor:default}
.location-name{display:inline-flex;align-items:center;gap:4px}
.location-tooltip-popup{display:none;position:absolute;bottom:calc(100% + 8px);left:0;background:#fff;border-radius:20px;box-shadow:0 1px 6px rgba(0,0,0,.18);padding:6px 14px;white-space:nowrap;z-index:1050;align-items:center;gap:6px}
.location-cell:hover .location-tooltip-popup{display:inline-flex}
.location-crumb{display:inline-flex;align-items:center;gap:4px;font-size:.8rem;color:#3c4043;font-weight:500}
.location-chevron{display:inline-flex;align-items:center}
.grid-card-location{position:relative;cursor:default}
.breadcrumb-hover-tooltip{position:absolute;bottom:calc(100% + 8px);left:0;background:#fff;border-radius:20px;box-shadow:0 1px 6px rgba(0,0,0,.18);padding:6px 14px;white-space:nowrap;z-index:1050;display:inline-flex;align-items:center;gap:6px;animation:tooltipFadeIn .15s ease}
@keyframes tooltipFadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
/* List Checkbox */
.checkbox-cell{width:40px;padding-left:12px!important;padding-right:0!important}
.list-checkbox-label{display:inline-flex;align-items:center;justify-content:center;margin:0;cursor:pointer;position:relative;width:20px;height:20px}
.list-checkbox-label input.list-checkbox{position:absolute;opacity:0;width:0;height:0}
.list-checkbox-custom{width:18px;height:18px;border:2px solid #b0b0b0;border-radius:3px;display:inline-block;position:relative;transition:all .15s ease;background:#fff}
.list-checkbox-label input.list-checkbox:checked+.list-checkbox-custom{background:#1a73e8;border-color:#1a73e8}
.list-checkbox-label input.list-checkbox:checked+.list-checkbox-custom::after{content:'';position:absolute;left:4px;top:1px;width:6px;height:10px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg)}
.list-checkbox-custom:hover{border-color:#5f6368}
.list-row.selected{background-color:#e8f0fe!important}
/* Grid Checkbox */
.grid-checkbox-label{display:inline-flex;align-items:center;justify-content:center;margin:0;margin-right:6px;cursor:pointer;position:relative;width:18px;height:18px;flex-shrink:0}
.grid-checkbox-label input.grid-checkbox{position:absolute;opacity:0;width:0;height:0}
.grid-checkbox-custom{width:16px;height:16px;border:2px solid #b0b0b0;border-radius:3px;display:inline-block;position:relative;transition:all .15s ease;background:#fff}
.grid-checkbox-label input.grid-checkbox:checked+.grid-checkbox-custom{background:#1a73e8;border-color:#1a73e8}
.grid-checkbox-label input.grid-checkbox:checked+.grid-checkbox-custom::after{content:'';position:absolute;left:3px;top:0px;width:6px;height:9px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg)}
.grid-checkbox-custom:hover{border-color:#5f6368}
.folder-grid-card.selected,.file-grid-card.selected{outline:2px solid #1a73e8;outline-offset:-2px}
/* Actions Dropdown */
.actions-dropdown{position:relative;margin-right:8px}
.actions-btn{display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
.actions-btn:disabled{color:#b0b0b0!important;border-color:#e0e0e0!important;background:#f8f9fa!important;cursor:default;pointer-events:none;opacity:1!important}
.actions-btn:disabled .actions-count{display:none}
.actions-count{font-size:.75rem;background:#1a73e8;color:#fff;border-radius:10px;padding:0 6px;min-width:18px;text-align:center;line-height:18px}
.actions-menu{display:none;position:absolute;top:100%;left:0;padding-top:4px;background:transparent;z-index:1050;min-width:220px}
.actions-menu-inner{background:#fff;border-radius:8px;box-shadow:0 1px 2px 0 rgba(60,64,67,.3),0 2px 6px 2px rgba(60,64,67,.15);padding:4px 0}
.actions-dropdown:hover .actions-menu{display:block}
.actions-dropdown:has(.actions-btn:disabled):hover .actions-menu{display:none}
.actions-option{display:flex;align-items:center;gap:10px;padding:8px 16px;color:#3c4043;font-size:.85rem;text-decoration:none;cursor:pointer;white-space:nowrap}
.actions-option:hover{background-color:#f1f3f4;text-decoration:none;color:#3c4043}
.actions-option-danger{color:#d93025}
.actions-option-danger:hover{background-color:#fce8e6;color:#d93025}
.actions-divider{height:1px;background:#e0e0e0;margin:4px 0}
.sort-dropdown{position:relative;margin-right:8px}
.sort-btn{display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
.sort-menu{display:none;position:absolute;top:100%;right:0;padding-top:4px;background:transparent;z-index:1050;min-width:180px}
.sort-menu-inner{background:#fff;border-radius:8px;box-shadow:0 1px 2px 0 rgba(60,64,67,.3),0 2px 6px 2px rgba(60,64,67,.15);padding:4px 0}
.sort-dropdown:hover .sort-menu{display:block}
.sort-option{display:flex;align-items:center;padding:8px 16px;color:#3c4043;font-size:.85rem;text-decoration:none;cursor:pointer;white-space:nowrap}
.sort-option:hover{background-color:#f1f3f4;text-decoration:none;color:#3c4043}
.sort-option.active{color:#1a73e8;font-weight:500}
.sort-option .sort-check{width:20px;margin-right:8px;display:inline-flex}
/* Copy File Browser Modal */
.fb-modal .modal-dialog{max-width:480px}
.fb-modal .modal-content{border:none;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.18)}
.fb-modal .modal-header{padding:20px 24px 12px;border-bottom:none}
.fb-modal .modal-title{font-size:1.1rem;font-weight:600;color:#202124}
.fb-modal .modal-body{padding:0}
.fb-breadcrumb{display:flex;align-items:center;gap:4px;padding:8px 24px;font-size:.8rem;color:#5f6368;flex-wrap:wrap}
.fb-breadcrumb-item{cursor:pointer;color:#1a73e8;font-weight:500;padding:2px 4px;border-radius:4px}
.fb-breadcrumb-item:hover{background:#e8f0fe}
.fb-breadcrumb-item.current{color:#3c4043;cursor:default;font-weight:600}
.fb-breadcrumb-item.current:hover{background:transparent}
.fb-breadcrumb-sep{color:#b0b0b0;font-size:.7rem}
.fb-folder-list{max-height:340px;min-height:200px;overflow-y:auto;border-top:1px solid #e8eaed;border-bottom:1px solid #e8eaed}
.fb-folder-item{display:flex;align-items:center;gap:10px;padding:10px 24px;cursor:pointer;color:#3c4043;font-size:.875rem;transition:background .1s}
.fb-folder-item:hover{background:#f1f3f4}
.fb-folder-item.selected{background:#e8f0fe}
.fb-folder-item svg{flex-shrink:0}
.fb-folder-name{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fb-folder-arrow{color:#b0b0b0;flex-shrink:0;display:flex;align-items:center}
.fb-empty{padding:40px 24px;text-align:center;color:#80868b;font-size:.875rem}
.fb-loading{padding:40px 24px;text-align:center;color:#80868b;font-size:.875rem}
.fb-modal .modal-footer{padding:12px 24px 20px;border-top:none;justify-content:flex-end;gap:8px}
.fb-modal .btn-copy{background:#1a73e8;color:#fff;border:none;border-radius:6px;padding:8px 24px;font-weight:500;font-size:.875rem}
.fb-modal .btn-copy:hover{background:#1557b0}
.fb-modal .btn-copy:disabled{background:#dadce0;color:#80868b;cursor:default}
.fb-modal .btn-cancel{background:transparent;color:#5f6368;border:none;padding:8px 16px;font-size:.875rem;border-radius:6px}
.fb-modal .btn-cancel:hover{background:#f1f3f4}
/* Home Dashboard */
.home-section-title{font-size:.8rem;font-weight:600;color:#5f6368;text-transform:uppercase;letter-spacing:.05em;margin-bottom:12px}
</style>
<div id="app-container">
  <!-- 1. Primary Sidebar (Icon Rail) -->
  <nav id="primary-sidebar">
    <div class="primary-nav-items">
      <!-- New (+) Button -->
      <div class="primary-nav-new-btn">
        <a href="#" class="primary-nav-item primary-new-btn" id="primaryNewBtn">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </a>
        <div class="primary-new-menu shadow-lg" id="primaryNewMenu">
          <a class="primary-new-menu-item" href="#" id="primaryNewFolder">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
              <line x1="12" y1="11" x2="12" y2="17"></line>
              <line x1="9" y1="14" x2="15" y2="14"></line>
            </svg>
            <span>New folder</span>
          </a>
          <div class="primary-new-menu-divider"></div>
          <a class="primary-new-menu-item" href="#" id="primaryFileUpload">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="12" y1="18" x2="12" y2="12"></line>
              <line x1="9" y1="15" x2="12" y2="12"></line>
              <line x1="15" y1="15" x2="12" y2="12"></line>
            </svg>
            <span>File upload</span>
          </a>
        </div>
      </div>

      <!-- Home -->
      <a href="{{ url('adminIndexList', null, { query: { view: 'home', layout: layoutMode, sort: sortMode } }) }}"
         class="primary-nav-item {% if viewMode == 'home' %}active{% endif %}"
         data-tooltip="Home"
         data-prefetch-view="home">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </a>

      <!-- My Drive -->
      <a href="{{ url('adminIndexList', { id: rootFolderId }, { query: { view: 'my-drive', tree: '1', layout: layoutMode, sort: sortMode } }) }}"
         class="primary-nav-item {% if viewMode == 'my-drive' %}active{% endif %}"
         id="btn-my-drive"
         data-tooltip="My Drive"
         data-prefetch-view="my-drive">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
        </svg>
      </a>

      <!-- Shared with me -->
      <a href="{{ url('adminIndexList', null, { query: { id: currentFolderId, view: 'shared-with-me', layout: layoutMode, sort: sortMode } }) }}"
         class="primary-nav-item {% if viewMode == 'shared-with-me' %}active{% endif %}"
         data-tooltip="Shared with me"
         data-prefetch-view="shared-with-me">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
      </a>

      <!-- Recent -->
      <a href="{{ url('adminIndexList', null, { query: { id: currentFolderId, view: 'recent', layout: layoutMode, sort: sortMode } }) }}"
         class="primary-nav-item {% if viewMode == 'recent' %}active{% endif %}"
         data-tooltip="Recent"
         data-prefetch-view="recent">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </a>

      <!-- Starred -->
      <a href="{{ url('adminIndexList', null, { query: { id: currentFolderId, view: 'starred', layout: layoutMode, sort: sortMode } }) }}"
         class="primary-nav-item {% if viewMode == 'starred' %}active{% endif %}"
         data-tooltip="Starred"
         data-prefetch-view="starred">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
      </a>

      <!-- Trash -->
      <a href="{{ url('adminIndexList', null, { query: { view: 'trash', layout: layoutMode, sort: sortMode } }) }}"
         class="primary-nav-item {% if viewMode == 'trash' %}active{% endif %}"
         data-tooltip="Trash"
         data-prefetch-view="trash">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"></polyline>
          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
        </svg>
      </a>

      <!-- Divider -->
      <div class="primary-nav-divider"></div>

      <!-- Settings -->
      <a href="#" class="primary-nav-item" data-tooltip="Settings">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
      </a>

      <!-- User Avatar Placeholder -->
      <div class="primary-nav-item profile-item">
        <div class="user-avatar">M</div>
      </div>
    </div>
  </nav>

  <!-- 2. Secondary Sidebar (Expandable Panel) -->
  <aside id="secondary-sidebar" class="sidebar-panel{% if not treeOpen %} collapsed{% endif %}">
      <div class="panel-header">
        <h5 class="panel-title">My Drive</h5>
        <!-- Optional: Close button or actions -->
      </div>
      
      <div class="panel-content">


         <!-- Folder Tree -->
         <div class="folder-tree-container">
            <ul class="nav flex-column folder-tree-root">
               {% if folderTree and folderTree.length > 0 %}
                {% set treeActiveId = currentFolderId %}
                {{ renderFolderTree(folderTree, 0, treeActiveId, viewMode, layoutMode) | safe }}
              {% else %}
                <li class="pl-3 text-muted small">No folders found</li>
              {% endif %}
            </ul>
         </div>
      </div>
      
      <!-- Resize Handle -->
      <div class="resize-handle"></div>
  </aside>

  <!-- 3. Main Content -->
  <main id="main-content" style="padding-left: 16px; padding-right: 016px;">
      <!-- Search Bar Area -->
      <div class="d-flex justify-content-center align-items-center py-3 mb-3 border-bottom search-container">
         <!-- Mobile Toggle -->
         <button id="mobile-sidebar-toggle" class="btn btn-link text-muted d-md-none mr-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
               <line x1="3" y1="12" x2="21" y2="12"></line>
               <line x1="3" y1="6" x2="21" y2="6"></line>
               <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
         </button>

         <div class="input-group search-bar">
          <div class="input-group-prepend">
            <span class="input-group-text bg-transparent border-0">
               <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </span>
          </div>
          <input type="text" id="search-input" class="form-control bg-transparent border-0" placeholder="Search in Drive" value="{{ searchQuery | e }}">
          <div id="search-clear-wrapper" class="input-group-append align-items-center justify-content-center" style="display: none;">
            <button type="button" id="search-clear" class="btn btn-link text-muted p-0 d-flex align-items-center justify-content-center" style="margin-right: 8px;" title="Clear search">
               <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Header with Toggle -->
      <div class="d-flex justify-content-between align-items-center mb-3">
         {% if viewMode == 'home' %}
           <h2 class="section-header mb-0">Home</h2>
         {% elif viewMode == 'search' %}
           <h2 class="section-header mb-0">Search results for "{{ searchQuery }}"</h2>
         {% elif viewMode == 'shared-with-me' %}
           <h2 class="section-header mb-0">Shared with me</h2>
         {% elif viewMode == 'recent' %}
           <h2 class="section-header mb-0">Recent</h2>
         {% elif viewMode == 'starred' %}
           <h2 class="section-header mb-0">Starred</h2>
         {% elif viewMode == 'trash' %}
           <h2 class="section-header mb-0">Trash</h2>
         {% else %}
           <h2 class="section-header mb-0">My Drive</h2>
         {% endif %}
         <div class="d-flex align-items-center" data-view="{{ viewMode }}">

            {% if viewMode == 'trash' %}

            {# ── Trash toolbar ── #}
            <div style="margin-right:8px">
              <button class="btn btn-sm btn-outline-secondary" id="btn-restore" type="button" disabled>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 .49-3.96"></path></svg>
                Restore
              </button>
            </div>
            <div style="margin-right:8px">
              <button class="btn btn-sm btn-outline-danger" id="btn-permanent-delete" type="button" disabled>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                Delete Permanently
              </button>
            </div>
            <div class="actions-dropdown" id="actions-dropdown">
              <button class="btn btn-sm btn-outline-secondary actions-btn" id="actions-btn" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
                Actions
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
              <div class="actions-menu">
                <div class="actions-menu-inner">
                  <a href="#" class="actions-option" id="trash-action-view-details" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    View details
                  </a>
                  <a href="#" class="actions-option" id="trash-action-download" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    Download
                  </a>
                  <a href="#" class="actions-option" id="trash-action-copy-location" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    Copy original location
                  </a>
                  <div class="actions-divider"></div>
                  <a href="#" class="actions-option" id="trash-action-select-all" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><polyline points="9 11 12 14 22 4"></polyline></svg>
                    Select all
                  </a>
                  <a href="#" class="actions-option" id="trash-action-clear-selection" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="15"></line><line x1="15" y1="9" x2="9" y2="15"></line></svg>
                    Clear selection
                  </a>
                  <div class="actions-divider"></div>
                  <a href="#" class="actions-option" id="action-restore-all" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 .49-3.96"></path></svg>
                    Restore All
                  </a>
                  <div class="actions-divider"></div>
                  <a href="#" class="actions-option actions-option-danger" id="action-empty-trash" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    Empty Trash
                  </a>
                </div>
              </div>
            </div>

            {% elif viewMode != 'home' %}

            {# ── Normal drive toolbar ── #}
            <div class="actions-dropdown" id="actions-dropdown">
              <button class="btn btn-sm btn-outline-secondary actions-btn" id="actions-btn" type="button" disabled>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 11 12 14 22 4"></polyline>
                  <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                </svg>
                Actions
                <span class="actions-count" id="actions-count"></span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="actions-menu">
                <div class="actions-menu-inner">
                  <a href="#" class="actions-option" id="action-calculate-size" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
                      <line x1="8" y1="6" x2="16" y2="6"></line>
                      <line x1="16" y1="14" x2="16" y2="18"></line>
                      <line x1="14" y1="16" x2="18" y2="16"></line>
                      <line x1="8" y1="10" x2="12" y2="10"></line>
                      <line x1="8" y1="14" x2="12" y2="14"></line>
                      <line x1="8" y1="18" x2="12" y2="18"></line>
                    </svg>
                    Calculate total size
                  </a>
                  <a href="#" class="actions-option" id="action-copy" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    Copy
                  </a>
                  <a href="#" class="actions-option" id="action-move" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                      <polyline points="13 2 13 9 20 9"></polyline>
                      <path d="M9 15h6"></path>
                      <path d="M12 18l3-3-3-3"></path>
                    </svg>
                    Move
                  </a>
                  <div class="actions-divider"></div>
                  <a href="#" class="actions-option actions-option-danger" id="action-trash" onclick="return false;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    Trash
                  </a>
                </div>
              </div>
            </div>

            {% endif %}

            {# Sort Dropdown — hidden on Home view #}
            {% if viewMode != 'home' %}
            <div class="sort-dropdown">
              <button class="btn btn-sm btn-outline-secondary sort-btn" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="4" y1="6" x2="16" y2="6"></line>
                  <line x1="4" y1="12" x2="12" y2="12"></line>
                  <line x1="4" y1="18" x2="8" y2="18"></line>
                  <polyline points="15 15 18 18 21 15"></polyline>
                  <line x1="18" y1="10" x2="18" y2="18"></line>
                </svg>
                {% if sortMode == 'owner' %}Owner{% elif sortMode == 'last_modified' %}Last Modified{% elif sortMode == 'size' %}File Size{% else %}Name{% endif %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="sort-menu">
                <div class="sort-menu-inner">
                <a href="{{ url('adminIndexList', { id: currentFolderId }, { query: { view: viewMode, layout: layoutMode, sort: 'name' } }) }}"
                   class="sort-option {% if sortMode == 'name' or not sortMode %}active{% endif %}">
                  <span class="sort-check">{% if sortMode == 'name' or not sortMode %}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a73e8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>{% endif %}</span>
                  Name
                </a>
                <a href="{{ url('adminIndexList', { id: currentFolderId }, { query: { view: viewMode, layout: layoutMode, sort: 'owner' } }) }}"
                   class="sort-option {% if sortMode == 'owner' %}active{% endif %}">
                  <span class="sort-check">{% if sortMode == 'owner' %}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a73e8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>{% endif %}</span>
                  Owner
                </a>
                <a href="{{ url('adminIndexList', { id: currentFolderId }, { query: { view: viewMode, layout: layoutMode, sort: 'last_modified' } }) }}"
                   class="sort-option {% if sortMode == 'last_modified' %}active{% endif %}">
                  <span class="sort-check">{% if sortMode == 'last_modified' %}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a73e8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>{% endif %}</span>
                  Last Modified
                </a>
                <a href="{{ url('adminIndexList', { id: currentFolderId }, { query: { view: viewMode, layout: layoutMode, sort: 'size' } }) }}"
                   class="sort-option {% if sortMode == 'size' %}active{% endif %}">
                  <span class="sort-check">{% if sortMode == 'size' %}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a73e8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>{% endif %}</span>
                  File Size
                </a>
                </div>
              </div>
            </div>
            {% endif %}{# end sort dropdown #}

            {# Layout Toggle #}
            <div class="btn-group" role="group" aria-label="Layout View">
              {% set listUrl = url('adminIndexList', { id: currentFolderId }, { query: { view: viewMode, layout: 'list', sort: sortMode } }) %}
              {% set gridUrl = url('adminIndexList', { id: currentFolderId }, { query: { view: viewMode, layout: 'grid', sort: sortMode } }) %}

              <a href="{{ listUrl }}" class="btn btn-sm btn-outline-secondary {% if layoutMode == 'list' %}active{% endif %}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="8" y1="6" x2="21" y2="6"></line>
                  <line x1="8" y1="12" x2="21" y2="12"></line>
                  <line x1="8" y1="18" x2="21" y2="18"></line>
                  <line x1="3" y1="6" x2="3.01" y2="6"></line>
                  <line x1="3" y1="12" x2="3.01" y2="12"></line>
                  <line x1="3" y1="18" x2="3.01" y2="18"></line>
                </svg>
              </a>
              <a href="{{ gridUrl }}" class="btn btn-sm btn-outline-secondary {% if layoutMode == 'grid' %}active{% endif %}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="7" height="7"></rect>
                  <rect x="14" y="3" width="7" height="7"></rect>
                  <rect x="14" y="14" width="7" height="7"></rect>
                  <rect x="3" y="14" width="7" height="7"></rect>
                </svg>
              </a>
            </div>
         </div>
      </div>

      {# ── Home Dashboard ── #}
      {% if viewMode == 'home' %}
        {% if homeSuggestions and (homeSuggestions.folders.length > 0 or homeSuggestions.files.length > 0) %}

          {# Suggested Folders #}
          {% if homeSuggestions.folders and homeSuggestions.folders.length > 0 %}
          <div class="home-section mb-4">
            <h6 class="home-section-title">Suggested folders</h6>
            {% if layoutMode == 'list' %}
              {{ listLayout(homeSuggestions.folders, starredFolderIds, starredFileIds, 'home', layoutMode) | safe }}
            {% else %}
              <div class="row mb-2">
                {{ gridLayout(homeSuggestions.folders, starredFolderIds, starredFileIds, 'home', layoutMode) | safe }}
              </div>
            {% endif %}
          </div>
          {% endif %}

          {# Suggested Files #}
          {% if homeSuggestions.files and homeSuggestions.files.length > 0 %}
          <div class="home-section">
            <h6 class="home-section-title">Suggested files</h6>
            {% if layoutMode == 'list' %}
              {{ listLayout(homeSuggestions.files, starredFolderIds, starredFileIds, 'home', layoutMode) | safe }}
            {% else %}
              <div class="row mb-2">
                {{ gridLayout(homeSuggestions.files, starredFolderIds, starredFileIds, 'home', layoutMode) | safe }}
              </div>
            {% endif %}
          </div>
          {% endif %}

        {% else %}
          <div class="text-center mt-5">
            <div class="mb-3">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#e0e0e0" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <p class="text-muted">Your suggested files and folders will appear here as you use the system.</p>
          </div>
        {% endif %}

      {% else %}

      {# Unified view: combined folders + files in a single list/grid with pagination #}
      {% if mergedItems and mergedItems.length > 0 %}
        {% if layoutMode == 'list' %}
          {{ listLayout(mergedItems, starredFolderIds, starredFileIds, viewMode, layoutMode) | safe }}
        {% else %}
          <div class="row mb-4">
            {{ gridLayout(mergedItems, starredFolderIds, starredFileIds, viewMode, layoutMode) | safe }}
          </div>
        {% endif %}
      {% elif (subFolders and subFolders.length > 0) or (filesList and filesList.length > 0) %}
        {% if layoutMode == 'list' %}
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th scope="col" style="width: 40%;">Name</th>
                  <th scope="col">Owner</th>
                  {% if viewMode == 'search' %}
                    <th scope="col">Location</th>
                  {% endif %}
                  <th scope="col">Last Modified</th>
                  <th scope="col" class="text-right">File Size</th>
                  <th scope="col"></th>
                </tr>
              </thead>
              <tbody>
                {% if subFolders and subFolders.length > 0 %}
                  {{ folderList(subFolders, viewMode, layoutMode, starredFolderIds) | safe }}
                {% endif %}
                {% if filesList and filesList.length > 0 %}
                  {{ fileList(filesList, starredFileIds, viewMode, layoutMode) | safe }}
                {% endif %}
              </tbody>
            </table>
          </div>
        {% else %}
          <div class="row mb-4">
            {% if subFolders and subFolders.length > 0 %}
              {{ folderGrid(subFolders, viewMode, layoutMode, starredFolderIds, false) | safe }}
            {% endif %}
            {% if filesList and filesList.length > 0 %}
              {{ fileGrid(filesList, starredFileIds, viewMode, layoutMode, false) | safe }}
            {% endif %}
          </div>
        {% endif %}
      {% endif %}

      {% if pagination %}
        {{ paginationWidget(pagination, viewMode, currentFolderId, searchQuery or '', layoutMode, sortMode) | safe }}
      {% endif %}

      {% if (not subFolders or subFolders.length == 0) and (not filesList or filesList.length == 0) %}
        <div class="text-center mt-5">
            <div class="mb-3">
                 <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#e0e0e0" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                 </svg>
            </div>
            <p class="text-muted">{% if viewMode == 'search' %}No results found for "{{ searchQuery }}"{% elif viewMode == 'trash' %}Trash is empty{% else %}This folder is empty{% endif %}</p>
        </div>
      {% endif %}

      {% endif %}{# end home else block #}

    </main>
</div>

  <!-- New Folder Modal -->
  <div class="modal fade" id="newFolderModal" tabindex="-1" role="dialog" aria-labelledby="newFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 400px;">
      <div class="modal-content border-0 shadow-lg" style="border-radius: 8px;">
        <div class="modal-body p-4">
          <h5 class="modal-title mb-3" id="newFolderModalLabel" style="font-weight: 400; font-size: 1.5rem;">New folder</h5>
          <form action="{{ url('adminFolderCreate') }}" method="POST">
            <input type="hidden" name="parent_folder_id" value="{{ currentFolderId }}">
            <div class="form-group mb-4">
              <input type="text" class="form-control p-2" id="newFolderName" name="name" value="Untitled folder" required style="border: 1px solid #1a73e8; border-radius: 4px;">
            </div>
            <div class="d-flex justify-content-end">
              <button type="button" class="btn btn-outline-secondary" data-dismiss="modal" style="margin-right: 16px;">Cancel</button>
              <button type="submit" class="btn btn-primary">Create</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Hidden file upload input -->
  <input type="file" id="fileUploadInput" multiple style="display: none;" onchange="handleMultiFileUpload(this)">

  <!-- Rename Folder Modal -->
  <div class="modal fade" id="renameFolderModal" tabindex="-1" role="dialog" aria-labelledby="renameFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header border-bottom-0">
          <h5 class="modal-title" id="renameFolderModalLabel">Rename</h5>
        </div>
        <div class="modal-body">
          <form id="renameFolderForm" onsubmit="return false;">
            <input type="hidden" id="renameFolderId" name="folder_id">
            <div class="form-group">
              <input type="text" class="form-control" id="renameFolderName" name="name" placeholder="Folder name" required>
            </div>
          </form>
        </div>
        <div class="modal-footer border-top-0">
          <button type="button" class="btn btn-text text-secondary" data-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary px-4" id="btnRenameFolderConfirm">OK</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Rename File Modal -->
  <div class="modal fade" id="renameFileModal" tabindex="-1" role="dialog" aria-labelledby="renameFileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header border-bottom-0">
          <h5 class="modal-title" id="renameFileModalLabel">Rename File</h5>
        </div>
        <div class="modal-body">
          <form id="renameFileForm">
            <input type="hidden" id="renameFileId" name="file_id">
            <div class="form-group">
              <div class="input-group">
                <input type="text" class="form-control" id="renameFileName" name="name" placeholder="File name" required>
                <div class="input-group-append">
                  <span class="input-group-text" id="renameFileExt"></span>
                </div>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer border-top-0">
          <button type="button" class="btn btn-text text-secondary" data-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary px-4" id="btnRenameFileConfirm">OK</button>
        </div>
      </div>
    </div>
  </div>

<!-- Delete Confirmation Modal (kept as is) -->
<div class="modal fade" id="deleteConfirmationModal" tabindex="-1" role="dialog" aria-labelledby="deleteConfirmationModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteConfirmationModalLabel">Confirm Deletion</h5>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to move this item to the trash?</p>
        <p class="text-danger">To confirm, type "<strong>Delete</strong>" in the box below.</p>
        <input type="text" id="deleteConfirmInput" class="form-control" placeholder="Type 'Delete' to confirm">
        <input type="hidden" id="deleteTargetUrl">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="button" id="confirmDeleteBtn" class="btn btn-danger" disabled>Delete</button>
      </div>
    </div>
  </div>
</div>
<!-- Share Modal -->
<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1" role="dialog" aria-labelledby="shareModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered share-modal-dialog" role="document">
    <div class="modal-content share-modal-content">

      <!-- Header -->
      <div class="modal-header share-modal-header">
        <h5 class="modal-title" id="shareModalLabel">Share</h5>
        <div class="share-header-actions">
            <button class="btn btn-icon" data-toggle="tooltip" title="Help">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#5f6368"><path d="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"/></svg>
            </button>
            <button class="btn btn-icon" data-toggle="tooltip" title="Settings">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#5f6368"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
            </button>
        </div>
      </div>

      <div class="modal-body share-modal-body">
        <input type="hidden" id="shareFileId">

        <!-- Add People Input -->
        <div class="share-input-wrapper mb-4">
            <div class="share-input-box">
                <input type="email" class="form-control share-input" id="shareEmailInput" placeholder="Add people, groups, spaces, and calendar events">
            </div>
        </div>

        <!-- People with Access List -->
        <div class="share-section mb-3">
            <h6 class="share-section-title">People with access</h6>
            <div class="share-access-list" id="shareAccessList">
                <div class="text-center text-muted small py-2">Loading...</div>
            </div>
        </div>

        <!-- General Access -->
        <div class="share-general-access-section">
            <h6 class="share-section-title">General access</h6>
            
             <div class="general-access-row">
                <div class="general-access-main">
                    <div class="access-icon-bg" id="generalAccessIcon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="#5f6368"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                    </div>
                    <div class="access-info-col">
                        <div class="select-wrapper">
                             <select class="custom-select access-select-main" id="generalAccessSelect">
                                <option value="restricted">Restricted</option>
                                <option value="public">Anyone with the link</option>
                            </select>
                        </div>
                        <div id="generalAccessDesc" class="access-desc">Only people with access can open with the link</div>
                    </div>
                </div>
                
                <div class="general-access-role">
                    <select class="custom-select access-role-select" id="publicLinkRoleSelect" style="display: none;">
                        <option value="viewer">Viewer</option>
                        <option value="editor">Editor</option>
                    </select>
                </div>
             </div>

             <!-- Info banner for public link -->
