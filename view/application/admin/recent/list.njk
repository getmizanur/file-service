{% extends 'layout/master.njk' %}

{% block content %}
<div id="app-container">
  {% include 'partial/admin/sidebar.njk' %}

  <!-- Main Content -->
  <main id="main-content" style="padding-left: 16px; padding-right: 16px;">
      {% include 'partial/admin/search-bar.njk' %}

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-3">
         <h2 class="section-header mb-0">Recent</h2>
         <div class="d-flex align-items-center" data-view="{{ viewMode }}">
            {% include 'partial/admin/toolbar-normal.njk' %}
            {% include 'partial/admin/sort-dropdown.njk' %}
            {% include 'partial/admin/layout-toggle.njk' %}
         </div>
      </div>

      {# Content: merged folders + files #}
      {% if mergedItems and mergedItems.length > 0 %}
        {% if layoutMode == 'list' %}
          {{ listLayout(mergedItems, starredFolderIds, starredFileIds, viewMode, layoutMode) | safe }}
        {% else %}
          <div class="row mb-4">
            {{ gridLayout(mergedItems, starredFolderIds, starredFileIds, viewMode, layoutMode) | safe }}
          </div>
        {% endif %}
      {% else %}
        <div class="text-center mt-5">
            <div class="mb-3">
                 <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#e0e0e0" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                 </svg>
            </div>
            <p class="text-muted">No recent files or folders</p>
        </div>
      {% endif %}

    </main>
</div>

{% include 'partial/admin/modals.njk' %}
{% endblock %}
