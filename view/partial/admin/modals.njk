<!-- Calculate Total Size Result Modal -->
<div class="modal fade" id="sizeResultModal" tabindex="-1" role="dialog" aria-labelledby="sizeResultModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="sizeResultModalLabel">Total size</h5>
      </div>
      <div class="modal-body text-center py-4">
        <div id="size-result-value" style="font-size:2rem;font-weight:600;color:#1a73e8;line-height:1.2;"></div>
        <div id="size-result-files" style="font-size:0.85rem;color:#5f6368;margin-top:6px;"></div>
      </div>
      <div class="modal-footer justify-content-center">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Trash Item Details Modal -->
<div class="modal fade" id="trashDetailsModal" tabindex="-1" role="dialog" aria-labelledby="trashDetailsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="trashDetailsModalLabel">Item details</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
      </div>
      <div class="modal-body" id="trash-details-body" style="font-size:.875rem;line-height:1.8;"></div>
      <div class="modal-footer justify-content-center">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>